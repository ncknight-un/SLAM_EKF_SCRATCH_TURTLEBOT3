<?xml version='1.0'?>
<launch>
    <!-- Launch the Nusim Node-->
    <node pkg='nusim' exec='nusimulator'>
        <param name='rate' value='100.0'/>
        <param name='x0' value='-0.6'/>
        <param name='y0' value='0.3'/>
        <param name='theta0' value='1.28'/>
    </node>

    <!-- Load the Redbot for Ground-->
    <include file='$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml'>
        <arg name='color' value='red'/>
        <arg name='use_rviz' value='false'/>
        <arg name='use_jsp' value='true'/>
    </include>

    <!-- RViz - If RViz is launched and closed, the launchfile will terminate-->
    <node pkg='rviz2' exec='rviz2' args='-d $(find-pkg-share nusim)/config/nusim.rviz' on_exit='shutdown'>
        <remap from='map' to='nusim/world'/>
    </node>
</launch>