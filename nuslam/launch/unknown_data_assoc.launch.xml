<?xml version="1.0"?>
<launch>
   <!-- Arguement to launch the robot simulation type -->
    <arg name="robot" default="nusim" 
        description="The user can control which robot simulation to launch.">
        <choice value="nusim" />
        <choice value="localhost" />
        <choice value="none" />
    </arg>

    <!-- Arguement to launch the command vel type -->
    <arg name="cmd_src" default="teleop" 
        description="The user can control which command velocity source to launch.">
        <choice value="circle" />
        <choice value="teleop" />
        <choice value="none" />
    </arg>

    <!-- Arguement to launch Rviz -->
    <arg name="use_rviz" default="true" 
        description="The user can control whether the turtlebot3 is shown in Rviz or not at launch. This is false for localhost">
        <choice value="true"/>
        <choice value="false"/>
    </arg>

    <!-- Arguement for config file -->
    <arg name="config_file" default="basic_world_laser_5obs" 
    description="The user can control what config file is used to load the world"/>

    <!-- ########################## Robot Siumulation ############################ -->
    <group if="$(eval '\'$(var robot)\'==\'nusim\'')">
        <!-- RViz Launch-->
        <node pkg="rviz2" exec="rviz2" args="-d $(find-pkg-share nuturtle_control)/config/load_slam_no_data_assoc.rviz" 
            if="$(eval '\'$(var use_rviz)\'==\'true\'')" on_exit="shutdown">
            <remap from='map' to='nusim/world'/>
        </node>

        <!-- Launch the Nusim Node if robot arg is nusim-->
        <node pkg="nusim" exec="nusimulator" if="$(eval '\'$(var robot)\'==\'nusim\'')">
            <param from = "$(find-pkg-share nusim)/config/$(var config_file).yaml"/>
            <remap from = "wheel_left_joint" to = "red/wheel_left_joint"/>
            <remap from = "wheel_right_joint" to = "red/wheel_right_joint"/>
        </node>

        <!-- Load the Redbot for Ground-->
        <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
            <arg name="color" value="red"/>
            <arg name="use_rviz" value="false"/>
            <arg name="use_jsp" value="false"/>
        </include>

        <!-- Launch Turtle Control -->
        <node pkg="nuturtle_control" exec="turtle_control">
            <param from = "$(find-pkg-share nuturtle_description)/config/diff_params.yaml"/>
            <remap from = "joint_states" to = "blue/joint_states"/>
            <remap from = "sensor_data" to = "red/sensor_data"/>
            <remap from = "wheel_cmd" to = "red/wheel_cmd"/>
        </node>

        <!-- ########################### cmd_src launch arguement ######################## -->
        <!-- Launch the circle Node if cmd_src arg is circle -->
        <node pkg="nuturtle_control" exec="circle" if="$(eval '\'$(var cmd_src)\'==\'circle\'')">
            <param name="frequency" value="100"/>
        </node>

        <!-- Publish the odometry SLAM node -->
        <node pkg="nuslam" exec="slam_odom" name="slam_odom">
            <param from = "$(find-pkg-share nuturtle_description)/config/diff_params.yaml"/>
            <param from = "$(find-pkg-share nuslam)/config/slam.yaml"/>
            <param name="body_id" value="green/base_footprint"/>
            <param name="odom_id" value="odom"/>
            <!-- Allow the blue to follow the nomenclature that is used in nusim for the red wheels. -->
            <param name="wheel_left" value="wheel_left_joint"/>
            <param name="wheel_right" value="wheel_right_joint"/>
            <remap from="joint_states" to="red/joint_states"/>
            <remap from="fake_obstacles" to="landmarks/scan_landmarks"/>
        </node>
        
        <!-- Load the Bluebot for odometry -->
        <include file='$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml'>
            <arg name='color' value='blue'/>
            <arg name='use_rviz' value='false'/> 
            <arg name='use_jsp' value='false'/>
        </include>

        <!-- Load the Greenbot for SLAM -->
        <include file='$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml'>
            <arg name='color' value='green'/>
            <arg name='use_rviz' value='$(var use_rviz)'/> 
            <!-- Set jsp to true because we are only publishing its tf -->
            <arg name='use_jsp' value='true'/> 
        </include>

        <!-- Load the Landmarks Node -->
        <node pkg="nuslam" exec="landmarks" name="landmarks">
            <param from = "$(find-pkg-share nuslam)/config/landmark_detect.yaml"/>
            <remap from="laser_scan_data" to="red/sim_scan"/>
        </node>
    </group>
</launch>